 <!DOCTYPE html>
<html lang="sr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Beogradski istraživač – uči srpski kroz igru</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #2d5a3b; font-family: 'Segoe UI', 'Comic Sans MS', cursive, sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
    .game-container { background: #f5f0d7; border-radius: 2.5rem; box-shadow: 0 20px 40px rgba(0,0,0,0.5); padding: 1.5rem; max-width: 900px; width: 100%; margin: 1rem; display: flex; flex-direction: column; gap: 1rem; }
    .header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    h1 { font-size: 1.8rem; color: #b45f2a; text-shadow: 2px 2px 0 #ffd966; }
    .goal-box { background: #ffd966; color: #4a2c1a; padding: 0.3rem 1rem; border-radius: 2rem; font-weight: bold; font-size: 0.9rem; }
    .mode-switch { display: flex; gap: 0.5rem; }
    .mode-btn { padding: 0.5rem 1.2rem; border: none; border-radius: 2rem; font-weight: bold; cursor: pointer; background: #c0a080; color: white; transition: 0.2s; }
    .mode-btn.active { background: #b45f2a; transform: scale(1.05); }
    canvas { width: 100%; height: auto; background: #e3d7b5; border: 4px solid #8b6f4c; border-radius: 2rem; display: block; margin: 0 auto; box-shadow: inset 0 0 20px rgba(0,0,0,0.3); }
    .chat-area { background: #fef9e3; border: 3px solid #b48b5a; border-radius: 1.5rem; padding: 0.8rem; display: flex; flex-direction: column; gap: 0.5rem; max-height: 220px; }
    .messages { flex: 1; overflow-y: auto; font-size: 0.95rem; padding-right: 0.5rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .msg { padding: 0.4rem 0.8rem; border-radius: 1rem; max-width: 85%; word-break: break-word; }
    .msg.user { align-self: flex-end; background: #b8d9b0; color: #1e3b20; }
    .msg.npc { align-self: flex-start; background: #f3d9b1; color: #4a2c1a; }
    .msg.system { align-self: center; background: #fff3cd; color: #856404; font-style: italic; font-size: 0.85rem; }
    .input-row { display: flex; gap: 0.5rem; }
    #userInput { flex: 1; padding: 0.6rem 1rem; border: 2px solid #b48b5a; border-radius: 2rem; font-size: 1rem; outline: none; }
    .send-btn { background: #b45f2a; color: white; border: none; border-radius: 2rem; padding: 0.6rem 1.5rem; cursor: pointer; font-weight: bold; }
    .yesno-btns { display: none; gap: 0.5rem; margin-top: 0.3rem; }
    .yesno-btns button { background: #9cb071; border: none; color: white; padding: 0.4rem 1rem; border-radius: 1rem; cursor: pointer; }
    .translation-hint { font-size: 0.85rem; color: #7a5d3c; }
  </style>
</head>
<body>
<div class="game-container">
  <div class="header">
    <h1>🚶 Beogradski istraživač</h1>
    <div class="goal-box" id="goalDisplay">🎯 Cilj: </div>
    <div class="mode-switch">
      <button id="easyModeBtn" class="mode-btn active">🌿 Laka verzija</button>
      <button id="hardModeBtn" class="mode-btn">🏙️ Teška verzija</button>
    </div>
  </div>
  <canvas id="mapCanvas" width="800" height="500" aria-label="Karta Beograda"></canvas>
  <div class="translation-hint" id="translationHint">👆 Klikni na zgradu da vidiš prevod na engleski</div>
  <div class="chat-area">
    <div class="messages" id="messages" aria-live="polite"></div>
    <div class="input-row">
      <input type="text" id="userInput" placeholder="npr. idi pravo pa levo..." autofocus>
      <button class="send-btn" id="sendBtn">Pošalji</button>
    </div>
    <div class="yesno-btns" id="yesnoButtons">
      <button id="yesBtn">Da</button>
      <button id="noBtn">Ne</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const canvas = document.getElementById('mapCanvas');
    const ctx = canvas.getContext('2d');
    const messagesDiv = document.getElementById('messages');
    const userInput = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const yesnoDiv = document.getElementById('yesnoButtons');
    const yesBtn = document.getElementById('yesBtn');
    const noBtn = document.getElementById('noBtn');
    const translationHint = document.getElementById('translationHint');
    const goalDisplay = document.getElementById('goalDisplay');

    let mode = 'easy';
    let playerNode = null;
    let playerOrientation = 0; // 0:up,1:right,2:down,3:left
    let inVehicle = null;
    let pendingCorrection = null;
    let vehicles = [];
    let goalBuilding = null;
    let sequenceQueue = [];
    let isProcessingSequence = false;

    let nodes = [];
    let edges = [];
    let buildings = [];
    let vehicleLines = [];

    const orientationTexts = {
      0: "severu ⬆️",
      1: "istoku ➡️",
      2: "jugu ⬇️",
      3: "zapadu ⬅️"
    };

    // ---------- HELPERS ----------
    function getNode(id) { return nodes.find(n => n.id === id); }
    function getBuildingByNode(nodeId) { return buildings.find(b => b.nodeId === nodeId); }
    function getBuildingById(id) { return buildings.find(b => b.id === id); }
    function getEffectiveNode() { return inVehicle ? inVehicle.positionNode : playerNode; }

    // ---------- MAP BUILD ----------
    function buildEasyMap() {
      nodes = [];
      edges = [];
      buildings = [];

      const nodeDefs = [
        { id: 'trg', x: 400, y: 280, label: 'Trg republike' },
        { id: 'knez_mihailova', x: 280, y: 200, label: 'Knez Mihailova (gornja)' },
        { id: 'kalemegdan', x: 160, y: 150, label: 'Kalemegdan' },
        { id: 'skadarlija', x: 520, y: 180, label: 'Skadarlija' },
        { id: 'terazije', x: 400, y: 360, label: 'Terazije' },
        { id: 'slavija', x: 550, y: 400, label: 'Slavija' },
        { id: 'vracar', x: 620, y: 320, label: 'Vračar (Hram)' },
        { id: 'dorcol', x: 300, y: 120, label: 'Dorćol' },
        { id: 'autokomanda', x: 660, y: 460, label: 'Autokomanda' },
        { id: 'zeleni_venac', x: 250, y: 340, label: 'Zeleni venac' }
      ];
      nodeDefs.forEach(def => {
        nodes.push({ id: def.id, x: def.x, y: def.y, label: def.label });
      });

      const streetDefs = [
        { from: 'trg', to: 'knez_mihailova', name: 'Knez Mihailova', orientation: 3 },
        { from: 'knez_mihailova', to: 'kalemegdan', name: 'Knez Mihailova (nastavak)', orientation: 3 },
        { from: 'trg', to: 'skadarlija', name: 'Ulica Kralja Petra', orientation: 1 },
        { from: 'skadarlija', to: 'vracar', name: 'Bulevar despota Stefana', orientation: 2 },
        { from: 'trg', to: 'terazije', name: 'Terazije', orientation: 2 },
        { from: 'terazije', to: 'slavija', name: 'Kralja Milana', orientation: 2 },
        { from: 'slavija', to: 'autokomanda', name: 'Bulevar oslobođenja', orientation: 2 },
        { from: 'terazije', to: 'zeleni_venac', name: 'Prizrenska', orientation: 3 },
        { from: 'trg', to: 'dorcol', name: 'Uskočka', orientation: 0 },
        { from: 'zeleni_venac', to: 'kalemegdan', name: 'Karađorđeva', orientation: 0 },
        { from: 'dorcol', to: 'skadarlija', name: 'Cara Dušana', orientation: 1 },
        // ISPRAVKA 3: Dodata ulica između Slavije i Vračara (Makenzijeva) da mapa ne bude isprekidana
        { from: 'slavija', to: 'vracar', name: 'Makenzijeva', orientation: 1 }
      ];

      streetDefs.forEach(s => {
        const fromNode = getNode(s.from);
        const toNode = getNode(s.to);
        if (fromNode && toNode) {
          // ISPRAVKA 2: Prioritet ima ručno podešena s.orientation ako postoji
          let orientation = s.orientation;
          if (orientation === undefined) {
            const dx = toNode.x - fromNode.x;
            const dy = toNode.y - fromNode.y;
            if (Math.abs(dx) >= Math.abs(dy)) orientation = dx > 0 ? 1 : 3;
            else orientation = dy > 0 ? 2 : 0;
          }
          edges.push({ from: s.from, to: s.to, orientation, name: s.name });
          edges.push({ from: s.to, to: s.from, orientation: (orientation + 2) % 4, name: s.name });
        }
      });

      buildings = [
        { id: 'biblioteka', nameSr: 'Narodna biblioteka', nameSrGen: 'Narodne biblioteke', nameEn: 'National Library', nodeId: 'skadarlija' },
        { id: 'muzej', nameSr: 'Narodni muzej', nameSrGen: 'Narodnog muzeja', nameEn: 'National Museum', nodeId: 'trg' },
        { id: 'skola', nameSr: 'Osnovna škola', nameSrGen: 'Osnovne škole', nameEn: 'Primary School', nodeId: 'vracar' },
        { id: 'galerija', nameSr: 'Galerija', nameSrGen: 'galerije', nameEn: 'Gallery', nodeId: 'knez_mihailova' },
        { id: 'pozoriste', nameSr: 'Pozorište', nameSrGen: 'pozorišta', nameEn: 'Theatre', nodeId: 'terazije' },
        { id: 'trzni_centar', nameSr: 'Tržni centar', nameSrGen: 'tržnog centra', nameEn: 'Shopping Centre', nodeId: 'slavija' },
        { id: 'park', nameSr: 'Kalemegdanski park', nameSrGen: 'Kalemegdanskog parka', nameEn: 'Kalemegdan Park', nodeId: 'kalemegdan' },
        { id: 'aerodrom', nameSr: 'Aerodrom', nameSrGen: 'aerodroma', nameEn: 'Airport', nodeId: 'autokomanda' },
        { id: 'stanica', nameSr: 'Autobuska stanica', nameSrGen: 'autobuske stanice', nameEn: 'Bus Station', nodeId: 'zeleni_venac' }
      ];

      playerNode = 'trg';
      playerOrientation = 2; 
      inVehicle = null;
      vehicles = [];
      pickNewGoal();
    }

    function buildHardMap() {
      buildEasyMap(); 
      mode = 'hard';  

      vehicleLines = [
        {
          id: 'bus18', type: 'autobus', color: '#1e4d8c', number: '18',
          // Sa novom Makenzijevom ulicom ova ruta sada ima pun geografski smisao
          stops: ['zeleni_venac', 'terazije', 'trg', 'skadarlija', 'vracar', 'slavija', 'autokomanda']
        },
        {
          id: 'trolley29', type: 'trolejbus', color: '#e87722', number: '29',
          stops: ['kalemegdan', 'knez_mihailova', 'trg', 'terazije', 'slavija']
        },
        {
          id: 'tram2', type: 'tramvaj', color: '#2d6a4f', number: '2',
          stops: ['dorcol', 'trg', 'terazije', 'zeleni_venac', 'kalemegdan']
        }
      ];

      vehicles = vehicleLines.map(line => ({
        ...line,
        currentStopIndex: 0,
        positionNode: line.stops[0]
      }));

      playerNode = 'trg';
      playerOrientation = 2;
      inVehicle = null;
      pickNewGoal();
    }

    function pickNewGoal() {
      const available = buildings.filter(b => b.nodeId !== getEffectiveNode());
      if (available.length > 0) {
        goalBuilding = available[Math.floor(Math.random() * available.length)];
      } else {
        goalBuilding = buildings[0];
      }
      updateGoalDisplay();
    }

    function updateGoalDisplay() {
      if (goalBuilding) {
        goalDisplay.textContent = `🎯 Cilj: ${goalBuilding.nameSr} (${goalBuilding.nameEn})`;
      } else {
        goalDisplay.textContent = `🎯 Cilj: ???`;
      }
    }

    // ---------- MOVEMENT ----------
    function canMoveForward() {
      const nodeId = getEffectiveNode();
      return edges.some(e => e.from === nodeId && e.orientation === playerOrientation);
    }

    function moveForward() {
      const edge = edges.find(e => e.from === getEffectiveNode() && e.orientation === playerOrientation);
      if (edge && !inVehicle) {
        playerNode = edge.to;
        checkGoal();
        return true;
      }
      return false;
    }

    function turnLeft() { playerOrientation = (playerOrientation + 3) % 4; }
    function turnRight() { playerOrientation = (playerOrientation + 1) % 4; }

    function checkGoal() {
      if (!goalBuilding) return;
      if (getEffectiveNode() === goalBuilding.nodeId) {
        npcMsg(`🎉 Bravo! Stigao/la si do ${goalBuilding.nameSrGen} (${goalBuilding.nameEn}). +10 poena!`);
        pickNewGoal();
        npcMsg(`Sledeći cilj: ${goalBuilding.nameSr}.`);
      }
    }

    // ---------- VEHICLE ACTIONS ----------
    function getVehicleAtNode(nodeId) { return vehicles.find(v => v.positionNode === nodeId); }
    function boardVehicle(vehicle) {
      if (inVehicle) return false;
      inVehicle = vehicle;
      return true;
    }
    function exitVehicle() {
      if (!inVehicle) return false;
      playerNode = inVehicle.positionNode;
      inVehicle = null;
      checkGoal();
      return true;
    }
    function moveVehicleByStops(vehicle, stops, skipGoalCheck = false) {
      const currentIdx = vehicle.currentStopIndex;
      let newIdx = currentIdx + stops;
      if (newIdx >= vehicle.stops.length) newIdx = vehicle.stops.length - 1;
      if (newIdx < 0) newIdx = 0;
      vehicle.currentStopIndex = newIdx;
      vehicle.positionNode = vehicle.stops[newIdx];
      // ISPRAVKA 1: Dodat flag kako bismo sprečili duplo okinanje checkGoal() funkcije
      if (inVehicle === vehicle && !skipGoalCheck) checkGoal();
      return newIdx;
    }

    function moveVehicleToBuilding(vehicle, buildingId) {
      const building = getBuildingById(buildingId);
      if (!building) return -1;
      const targetIdx = vehicle.stops.indexOf(building.nodeId);
      if (targetIdx !== -1) {
        const diff = targetIdx - vehicle.currentStopIndex;
        // Ovde preskačemo interni checkGoal jer se on odmah potom izvršava u exitVehicle()
        return moveVehicleByStops(vehicle, diff, true);
      }
      return -1;
    }

    // ---------- PARSER ----------
    const directionWords = { 'pravo': 'forward', 'napred': 'forward', 'levo': 'turnLeft', 'lijevo': 'turnLeft', 'desno': 'turnRight' };
    const numberWords = {
      'jednu':1,'jedan':1,'dve':2,'dva':2,'tri':3,'četiri':4,'četri':4,'pet':5,
      'šest':6,'sedam':7,'osam':8,'devet':9,'deset':10,
      'jedanaest':11,'dvanaest':12,'trinaest':13,'četrnaest':14,'petnaest':15
    };

    function tokenize(input) {
      return input.trim().toLowerCase().replace(/[?!,.]/g,'').split(/\s+/);
    }

    function parseSingleCommand(tokens) {
      const clean = tokens.filter(t => !['molim','te','vas','malo','odmah','sada','polako'].includes(t));
      if (clean.length === 0) return null;
      if (['pomoć','help','komande'].some(w => clean.includes(w))) return { action:'help' };
      if (['pogledaj','gde','šta'].some(w => clean.includes(w))) return { action:'look' };

      for (const [dir, action] of Object.entries(directionWords)) {
        if (clean.includes(dir)) {
          const hasVerb = clean.some(t => ['idite','idi','hodaj','produžite','nastavite','skrenite','skreni'].includes(t));
          if (hasVerb || clean.length <= 2) {
            return { action };
          }
        }
      }

      if (mode === 'hard') {
        const uciIdx = clean.indexOf('ući');
        if (uciIdx !== -1 && clean[uciIdx+1] === 'u') {
          const typeWord = clean[uciIdx+2];
          const typeMap = { 'autobus':'autobus','bus':'autobus','trolejbus':'trolejbus','trola':'trolejbus','tramvaj':'tramvaj','tram':'tramvaj' };
          if (typeMap[typeWord]) {
            let number = null;
            const brojIdx = clean.indexOf('broj');
            if (brojIdx !== -1 && clean[brojIdx+1]) number = clean[brojIdx+1];
            return { action:'enterVehicle', vehicleType: typeMap[typeWord], number };
          }
        }
        if (clean.includes('izađi')) {
          const kodIdx = clean.indexOf('kod');
          let buildingName = null;
          if (kodIdx !== -1 && clean.slice(kodIdx+1).length > 0) {
            buildingName = clean.slice(kodIdx+1).join(' ');
          }
          return { action:'exitVehicle', buildingName };
        }
        const voziIdx = clean.findIndex(t => t === 'vozi' || t === 'voziti');
        if (voziIdx !== -1 && clean[voziIdx+1] === 'se') {
          const countWord = clean[voziIdx+2];
          if (countWord && (numberWords[countWord] || /^\d+$/.test(countWord))) {
            const num = numberWords[countWord] || parseInt(countWord,10);
            if (num) return { action:'travelStops', count: num };
          }
        }
      }
      return null;
    }

    function parseSequence(input) {
      const parts = input.split(/\s+(?:pa|zatim|onda|i)\s+/);
      return parts.map(p => tokenize(p)).filter(t => t.length > 0);
    }

    // ---------- MESSAGES & PROCESSING ----------
    function addMessage(sender,text){
      const d=document.createElement('div');
      d.className=`msg ${sender}`;
      d.textContent=text;
      messagesDiv.appendChild(d);
      messagesDiv.scrollTop=messagesDiv.scrollHeight;
    }
    function npcMsg(t){addMessage('npc',t);}
    function userMsg(t){addMessage('user',t);}

    function describeLocation(){
      const nodeId = getEffectiveNode();
      const b = getBuildingByNode(nodeId);
      const smer = orientationTexts[playerOrientation];
      if(b) return `Nalaziš se kod ${b.nameSrGen} (${b.nameEn}). Gledaš ka ${smer}.`;
      return `Nalaziš se na raskrsnici. Gledaš ka ${smer}.`;
    }

    function showHelp(){
      if(mode==='easy'){
        npcMsg('Komande: "pravo", "levo", "desno", "pogledaj". Možeš i spojiti: "idi pravo pa levo".');
      } else {
        npcMsg('Komande: "pravo", "levo", "desno", "ući u autobus/trolejbus/tramvaj", "izađi [kod zgrade]", "vozi se X stanica", "pogledaj".');
      }
    }

    function executeCommand(parsedCmd) {
      if (!parsedCmd) return;
      if (parsedCmd.action === 'help') { showHelp(); return; }
      if (parsedCmd.action === 'look') { npcMsg(describeLocation()); return; }

      if (parsedCmd.action === 'forward') {
        if (inVehicle) { npcMsg('Prvo izađi iz vozila.'); return; }
        if (canMoveForward()) {
          if (moveForward()) {
            npcMsg('Idem pravo. ✔️ ' + describeLocation());
          } else {
            npcMsg('Ne mogu pravo.');
          }
        } else {
          npcMsg('Ne mogu pravo, ispred je kraj puta.');
        }
      }
      else if (parsedCmd.action === 'turnLeft') {
        if (inVehicle) { npcMsg('Ne možeš skretati u vozilu.'); return; }
        turnLeft();
        npcMsg('Skrećem levo. ↩️ ' + describeLocation());
      }
      else if (parsedCmd.action === 'turnRight') {
        if (inVehicle) { npcMsg('Ne možeš skretati u vozilu.'); return; }
        turnRight();
        npcMsg('Skrećem desno. ↪️ ' + describeLocation());
      }
      else if (parsedCmd.action === 'enterVehicle') {
        if (mode !== 'hard') { npcMsg('Prevoz samo u teškoj verziji.'); return; }
        const veh = getVehicleAtNode(getEffectiveNode());
        if (!veh) { npcMsg('Ovde nema vozila.'); return; }
        if (inVehicle) { npcMsg('Već si u vozilu.'); return; }
        if (veh.type !== parsedCmd.vehicleType) { npcMsg(`Ovde je ${veh.type} ${veh.number}.`); return; }
        if (parsedCmd.number && veh.number !== parsedCmd.number) { npcMsg(`Broj ne odgovara.`); return; }
        boardVehicle(veh);
        npcMsg(`Ušao/la si u ${veh.type} ${veh.number}.`);
      }
      else if (parsedCmd.action === 'exitVehicle') {
        if (!inVehicle) { npcMsg('Nisi u vozilu.'); return; }
        if (parsedCmd.buildingName) {
          const b = buildings.find(b=> b.nameSr.toLowerCase()===parsedCmd.buildingName || b.nameSrGen.toLowerCase()===parsedCmd.buildingName || b.id===parsedCmd.buildingName);
          if (!b) { npcMsg('Ne znam tu zgradu.'); return; }
          const moved = moveVehicleToBuilding(inVehicle, b.id);
          if (moved === -1) { npcMsg('Ta zgrada nije na liniji.'); return; }
          exitVehicle();
          npcMsg(`Izašao/la si kod ${b.nameSrGen}. ` + describeLocation());
        } else {
          exitVehicle();
          npcMsg('Izašao/la si iz vozila. ' + describeLocation());
        }
      }
      else if (parsedCmd.action === 'travelStops') {
        if (!inVehicle) { npcMsg('Prvo uđi u vozilo.'); return; }
        const num = parsedCmd.count;
        const newIdx = moveVehicleByStops(inVehicle, num);
        const b = getBuildingByNode(inVehicle.positionNode);
        const lok = b ? `kod ${b.nameSrGen}` : 'na raskrsnici';
        npcMsg(`Vozio/la si se ${num} stanice. Sada si ${lok}.`);
        if (newIdx === inVehicle.stops.length-1) npcMsg('Poslednja stanica.');
      }
    }

    function processCommand(rawInput) {
      userMsg(rawInput);

      const tokenSequences = parseSequence(rawInput);
      if (tokenSequences.length > 1) {
        sequenceQueue = tokenSequences.map(tokens => parseSingleCommand(tokens)).filter(c => c);
        isProcessingSequence = true;
        processNextInSequence();
        return;
      }

      const singleTokens = tokenize(rawInput);
      const parsed = parseSingleCommand(singleTokens);
      if (!parsed) {
        const suggestion = findSuggestion(rawInput);
        if (suggestion) {
          pendingCorrection = { original: rawInput, corrected: suggestion };
          npcMsg(`Da li ste mislili na "${suggestion}"?`);
          yesnoDiv.style.display = 'flex';
          userInput.disabled = true;
          sendBtn.disabled = true;
          return;
        }
        npcMsg('Izvini, nisam te razumeo. 😕 Pokušaj "pomoć".');
        return;
      }

      executeCommand(parsed);
      drawMap();
    }

    function processNextInSequence() {
      if (!isProcessingSequence || sequenceQueue.length === 0) {
        isProcessingSequence = false;
        drawMap();
        return;
      }
      const cmd = sequenceQueue.shift();
      executeCommand(cmd);
      drawMap();
      if (sequenceQueue.length > 0) {
        setTimeout(() => processNextInSequence(), 600);
      } else {
        isProcessingSequence = false;
      }
    }

    function findSuggestion(input) {
      const clean = input.trim().toLowerCase();
      const samples = mode==='easy'?
        ['idi pravo','skreni levo','skreni desno','pogledaj']:
        ['idi pravo','skreni levo','skreni desno','ući u autobus','izađi','vozi se dve stanice'];
      let best=null, dist=Infinity;
      for(const s of samples){
        const d = levenshtein(clean,s);
        if(d<dist && d<=3){ dist=d; best=s; }
      }
      return best;
    }

    function levenshtein(a,b) {
      const m = Array(b.length+1).fill(null).map(()=>Array(a.length+1).fill(null));
      for (let i=0;i<=b.length;i++) m[i][0]=i;
      for (let j=0;j<=a.length;j++) m[0][j]=j;
      for (let i=1;i<=b.length;i++)
        for (let j=1;j<=a.length;j++)
          m[i][j]=Math.min(m[i-1][j]+1,m[i][j-1]+1,m[i-1][j-1]+(a[j-1]===b[i-1]?0:1));
      return m[b.length][a.length];
    }

    // ---------- DRAWING ----------
    function drawMap(){
      ctx.clearRect(0,0,canvas.width,canvas.height);
      drawRoads();
      if(mode==='hard') drawVehicleLines();
      drawBuildings();
      drawPlayer();
      drawVehicles();
    }

    function drawRoads(){
      const drawn = new Set();
      edges.forEach(e=>{
        const key = [e.from,e.to].sort().join('-');
        if(drawn.has(key)) return;
        drawn.add(key);
        const f=getNode(e.from), t=getNode(e.to);
        if(f&&t){
          ctx.strokeStyle='#aaa';
          ctx.lineWidth=3;
          ctx.beginPath();
          ctx.moveTo(f.x,f.y);
          ctx.lineTo(t.x,t.y);
          ctx.stroke();
          if (e.name) {
            ctx.fillStyle='#555';
            ctx.font='9px "Segoe UI"';
            ctx.textAlign='center';
            const mx = (f.x+t.x)/2, my = (f.y+t.y)/2;
            ctx.fillText(e.name, mx, my-5);
          }
        }
      });
    }

    function drawVehicleLines(){
      vehicleLines.forEach(line=>{
        ctx.setLineDash([8,8]);
        ctx.strokeStyle=line.color;
        ctx.lineWidth=3;
        ctx.beginPath();
        const points=line.stops.map(id=>getNode(id)).filter(n=>n);
        if(points.length>1){
          ctx.moveTo(points[0].x,points[0].y);
          for(let i=1;i<points.length;i++) ctx.lineTo(points[i].x,points[i].y);
          ctx.stroke();
        }
        ctx.setLineDash([]);
      });
    }

    function drawBuildings(){
      buildings.forEach(b=>{
        const node=getNode(b.nodeId);
        if(!node) return;
        const x=node.x, y=node.y;
        ctx.fillStyle='#c48b5c';
        ctx.fillRect(x-22, y-24, 44, 32);
        ctx.fillStyle='#8b5a2b';
        ctx.fillRect(x-18, y-20, 36, 24);
        ctx.fillStyle='white';
        ctx.font='bold 10px "Segoe UI"';
        ctx.textAlign='center';
        ctx.fillText(b.nameSr, x, y-30);
        b.hitRect={x:x-25, y:y-35, w:50, h:50};
      });
    }

    function drawPlayer(){
      if(inVehicle) return;
      const node=getNode(getEffectiveNode());
      if(!node) return;
      ctx.save();
      ctx.translate(node.x,node.y);
      ctx.fillStyle='#ffcc00';
      ctx.beginPath();
      ctx.rotate((playerOrientation*Math.PI)/2 - Math.PI/2);
      ctx.moveTo(0,-7);
      ctx.lineTo(6,5);
      ctx.lineTo(-6,5);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
      ctx.fillStyle='#d94f4f';
      ctx.beginPath();
      ctx.arc(node.x,node.y,12,0,2*Math.PI);
      ctx.fill();
      ctx.fillStyle='white';
      ctx.font='16px sans-serif';
      ctx.textAlign='center';
      ctx.fillText('🧑',node.x,node.y+5);
    }

    function drawVehicles(){
      vehicles.forEach(v=>{
        const node=getNode(v.positionNode);
        if(!node) return;
        const vx=node.x+24, vy=node.y+12;
        ctx.fillStyle=v.color;
        ctx.beginPath();
        ctx.ellipse(vx,vy-2,16,10,0,0,Math.PI*2);
        ctx.fill();
        ctx.fillStyle='white';
        ctx.font='bold 10px sans-serif';
        ctx.textAlign='center';
        ctx.fillText(v.number,vx,vy-5);
        if(inVehicle===v){
          ctx.fillStyle='#d94f4f';
          ctx.beginPath();
          ctx.arc(vx-6,vy-8,5,0,2*Math.PI);
          ctx.fill();
          ctx.fillText('🧑',vx-6,vy-5);
        }
      });
    }

    canvas.addEventListener('click',(e)=>{
      const rect=canvas.getBoundingClientRect();
      const scaleX=canvas.width/rect.width;
      const scaleY=canvas.height/rect.height;
      const mx=(e.clientX-rect.left)*scaleX;
      const my=(e.clientY-rect.top)*scaleY;
      for(let b of buildings){
        if(b.hitRect && mx>=b.hitRect.x && mx<=b.hitRect.x+b.hitRect.w && my>=b.hitRect.y && my<=b.hitRect.y+b.hitRect.h){
          translationHint.textContent=`📖 ${b.nameSr} = ${b.nameEn}`;
          return;
        }
      }
    });

    function switchMode(newMode){
      mode=newMode;
      document.getElementById('easyModeBtn').classList.toggle('active',mode==='easy');
      document.getElementById('hardModeBtn').classList.toggle('active',mode==='hard');
      pendingCorrection=null;
      yesnoDiv.style.display='none';
      userInput.disabled=false;
      sendBtn.disabled=false;
      sequenceQueue = [];
      isProcessingSequence = false;
      if(mode==='easy') buildEasyMap(); else buildHardMap();
      inVehicle=null;
      drawMap();
      messagesDiv.innerHTML='';
      npcMsg('Zdravo! Možeš li mi reći kako da dođem do cilja? Koristi "pravo", "levo", "desno", ili složi više komandi.');
      userInput.focus();
    }

    document.getElementById('easyModeBtn').addEventListener('click',()=>switchMode('easy'));
    document.getElementById('hardModeBtn').addEventListener('click',()=>switchMode('hard'));

    sendBtn.addEventListener('click',()=>{
      if(userInput.value.trim()==='') return;
      processCommand(userInput.value.trim());
      userInput.value='';
      if(!pendingCorrection) userInput.focus();
    });
    userInput.addEventListener('keypress',(e)=>{ if(e.key==='Enter') sendBtn.click(); });

    // ISPRAVKA 4: Dugmad za potvrdu ispravki sada rukuju stanjem bez dodavanja "da/ne" u chat istoriju
    yesBtn.addEventListener('click',()=>{
      if (pendingCorrection) {
        const corrected = pendingCorrection.corrected;
        pendingCorrection = null;
        yesnoDiv.style.display = 'none';
        userInput.disabled = false;
        sendBtn.disabled = false;
        userInput.value = '';
        processCommand(corrected);
      }
    });
    noBtn.addEventListener('click',()=>{
      pendingCorrection = null;
      yesnoDiv.style.display = 'none';
      userInput.disabled = false;
      sendBtn.disabled = false;
      npcMsg('U redu, pokušaj ponovo.');
      userInput.value = '';
      userInput.focus();
    });

    document.addEventListener('keydown',(e)=>{
      if(e.key==='Escape' && pendingCorrection){
        pendingCorrection=null;
        yesnoDiv.style.display='none';
        userInput.disabled=false;
        sendBtn.disabled=false;
        npcMsg('Odustao/la si od ispravke.');
        userInput.focus();
      }
    });

    buildEasyMap();
    drawMap();
    npcMsg('Zdravo! Odvedi me do cilja. Možeš koristiti "idi pravo pa levo" za složenije rute.');
  })();
</script>
